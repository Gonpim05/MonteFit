<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MonteFit" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_power_light</item>
        <item name="colorPrimaryDark">@color/accent_power</item>
        <item name="colorSecondary">@color/accent_gold</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/bg_light_card</item>
        <item name="colorOnSurface">@color/text_light_primary</item>
        <item name="android:colorBackground">@color/bg_light_main</item>
        <item name="android:windowBackground">@color/bg_light_main</item>
        <item name="android:statusBarColor">@color/bg_light_main</item>
        <item name="android:navigationBarColor">@color/bg_light_main</item>
        <item name="android:textColorPrimary">@color/text_light_primary</item>
        <item name="android:textColorSecondary">@color/text_light_secondary</item>
        <item name="android:editTextColor">@color/text_light_primary</item>
        <item name="alertDialogTheme">@style/Theme.MonteFit.Dialog</item>
    </style>

    <style name="Theme.MonteFit.Dialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@color/bg_light_card</item>
        <item name="android:textColorPrimary">@color/text_light_primary</item>
        <item name="colorSurface">@color/bg_light_card</item>
        <item name="colorOnSurface">@color/text_light_primary</item>
    </style>

    <style name="Theme.MonteFit" parent="Base.Theme.MonteFit" />
</resources>